{
  "name": "copy-debug-variable",
  "displayName": "Copy Debug Variable",
  "description": "High-performance extension for copying and comparing debugger variables with Turbo Serialization.",
  "version": "1.1.0",
  "icon": "extension_logo.png",
  "publisher": "doquochao95",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doquochao95/Copy-Debug-Variable.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "debug",
    "copy",
    "compare",
    "json",
    "variable",
    ".net",
    "csharp",
    "typescript",
    "javascript"
  ],
  "activationEvents": [
    "onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyDebugVariable.copyValue",
        "title": "Copy Variable Value"
      },
      {
        "command": "copyDebugVariable.selectForCompare",
        "title": "Select for Compare"
      },
      {
        "command": "copyDebugVariable.compareWithSelected",
        "title": "Compare with Selected"
      }
    ],
    "menus": {
      "debug/variables/context": [
        {
          "command": "copyDebugVariable.copyValue",
          "group": "1_modification"
        },
        {
          "command": "copyDebugVariable.selectForCompare",
          "group": "2_compare@1"
        },
        {
          "command": "copyDebugVariable.compareWithSelected",
          "group": "2_compare@2",
          "when": "copyDebugVariable.hasSelectedForCompare"
        }
      ]
    },
    "configuration": {
      "title": "Copy Debug Variable",
      "properties": {
        "copyDebugVariable.format": {
          "type": "string",
          "enum": ["json", "plain"],
          "default": "json",
          "description": "Format for copying variable values"
        },
        "copyDebugVariable.maxDepth": {
          "type": "number",
          "default": 10,
          "description": "Maximum depth for nested structures"
        },
        "copyDebugVariable.truncateLarge": {
          "type": "boolean",
          "default": true,
          "description": "Truncate large data structures"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "build": "npm run compile",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
